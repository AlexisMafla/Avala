# --- Avala service configuration ---

# HTTP port for the REST + MCP server
PORT=8787

# --- Payments (Tempo TIP-20 on Moderato testnet) ---
# When PAY_TO is empty the service runs in FREE/DEV mode.
# See docs/MONETIZATION.md for the full activation guide.

# Wallet address that receives payments on Tempo (your revenue wallet)
PAY_TO=

# Tempo Moderato testnet (chain ID 42431, CAIP-2)
X402_NETWORK=eip155:42431

# Tempo JSON-RPC endpoint (used to verify on-chain pathUSD transfers)
TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz

# Optional — legacy x402 facilitator URL (not used; verification is on-chain)
# X402_FACILITATOR_URL=

# pathUSD on Tempo Moderato (6 decimals)
X402_ASSET=0x20c0000000000000000000000000000000000000
X402_ASSET_DECIMALS=6

# Price per call in atomic units (2000 = 0.002 pathUSD)
PRICE_ATOMIC=2000
