{
  "name": "avala-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Avala - Pay-per-call validation of IBANs, tax IDs and bank accounts for Spain, Colombia and Argentina. Monetized via x402/MPP on Tempo and exposed as an MCP server.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/http/server.ts",
    "start": "node dist/http/server.js",
    "mcp": "tsx src/mcp/stdio.ts",
    "build": "tsc -p tsconfig.json",
    "build:web": "npm run build --prefix web",
    "build:all": "npm run build:web && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "payments:check": "tsx scripts/check-payments.ts",
    "postinstall": "node scripts/patch-agentgate.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tempo-agentgate/core": "^0.1.1",
    "@tempo-agentgate/middleware": "^0.1.1",
    "hono": "^4.12.27",
    "viem": "^2.53.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
